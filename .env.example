# Local PostgreSQL (no Docker). Adjust Username/Password to your install.
# Peer auth on Linux (omit user/password if your OS user owns the DB):
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=helpdesk_lite
Jwt__SigningKey=ChangeMeToASecureKeyWithAtLeast32Characters!!
Jwt__Issuer=HelpDeskLite
Jwt__Audience=HelpDeskLite
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000
ASPNETCORE_ENVIRONMENT=Development
SeedData__Enabled=true
